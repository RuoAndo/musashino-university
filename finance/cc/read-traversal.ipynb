    "import pandas as pd\n",
    "import os\n",
    "\n",
    "dir_path = r\"D:\\musashino-university\\finance\\cc\"\n",
    "\n",
    "dfs = {}\n",
    "\n",
    "for file in os.listdir(dir_path):\n",
    "\n",
    "    if file.endswith(\".csv\"):\n",
    "\n",
    "        path = os.path.join(dir_path, file)\n",
    "\n",
    "        df = pd.read_csv(path)\n",
    "\n",
    "        dfs[file] = df\n",
    "\n",
    "\n",
    "print(\"時系列数 =\", len(dfs))"
   ]
  }
 ],
